# ── Builder Code ────────────────────────────────────────────────────
# Register at dashboard.base.org → Settings → Builder Codes
# Format: ^[a-z0-9_]{1,32}$
BUILDER_CODE=bc_rfgagdy3

# ── Hub Wallet (hot — lives on the server) ──────────────────────────
# Holds USDC float (pays upstreams) + ETH for gas (logAttribution txs).
# Only authorized to call RouteRegistry.logAttribution(). NOT the contract owner.
# Generate: cast wallet new
HUB_PRIVATE_KEY=
HUB_ADDRESS=

# ── Deployer Wallet ──────────────────────────────────────────────────
# Uses the "speedrun" Foundry keystore (~/.foundry/keystores/speedrun).
# Address: 0x8F058fE6b568D97f85d517Ac441b52B95722fDDe
#
# The private key NEVER goes in any file — keystore only.
# Verify: cast wallet list  (must show "speedrun")
# Deploy: forge script ... --account speedrun --sender <DEPLOYER_ADDRESS>
#
# Only the public address is needed here:
DEPLOYER_ADDRESS=0x8F058fE6b568D97f85d517Ac441b52B95722fDDe

# ── CDP Facilitator ─────────────────────────────────────────────────
# API keys from portal.cdp.coinbase.com → API Keys
# Required for verify + settle endpoints (getSupported also returns 401 without them)
FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# ── Hub Domain ──────────────────────────────────────────────────────
# The public domain where the server is deployed (no trailing slash)
HUB_DOMAIN=

# ── Upstream API Keys ───────────────────────────────────────────────
STABLECRYPTO_API_KEY=
QUICKNODE_API_KEY=
STABLEENRICH_API_KEY=

# ── Server ──────────────────────────────────────────────────────────
PORT=3001
BASE_RPC_URL=https://mainnet.base.org

# ── RouteRegistry contract ───────────────────────────────────────────
# Set after deploying contracts/src/RouteRegistry.sol.
# Absent = on-chain attribution logging is skipped (no error).
REGISTRY_ADDRESS=

# ── Basescan (for contract verification only, not runtime) ───────────
BASESCAN_API_KEY=
