# Hub server URL (no trailing slash)
NEXT_PUBLIC_HUB_URL=http://localhost:3001

# WalletConnect project ID from cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# RouteRegistry contract address on Base mainnet (from forge script output)
# Used for on-chain attribution count and history — read-only, no signing needed
NEXT_PUBLIC_REGISTRY_ADDRESS=
